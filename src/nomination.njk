---
layout: base.njk
pagination:
  data: nominations
  size: 1
  alias: nom
permalink: "nomination/{{ nom.id }}/"
---

{% set journalNames = {
  "JCRe": "JCRe",
  "JRR": "Journal of Robustness Research",
  "R2": "Replication Research",
  "RC": "Rescience C",
  "RX": "Rescience X"
} %}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <a href="{{ '/browse/' | url }}" class="back-link">&larr; Back to Browse</a>
</div>

<h1 style="margin-top: 0;">{{ nom.title }}</h1>

<!-- Interaction Mechanics Box -->
<div style="background: var(--table-hover); border: 1px solid var(--border); padding: 15px 25px; margin-bottom: 25px; border-radius: 6px; display: flex; flex-wrap: wrap; gap: 20px; align-items: center; justify-content: space-between;">
  <div>
    <h4 style="margin: 0 0 5px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 0.95rem; text-transform: uppercase;">Community Mechanics</h4>
    <p style="margin: 0; font-size: 0.9rem; color: var(--text-muted);">
      Login to GitHub and react to the original post to record your vote: <br>
      <strong>👍 Endorse</strong> | <strong>🎉 Predict Success</strong> | <strong>😕 Predict Failure</strong>
    </p>
  </div>
  
  <div style="display: flex; gap: 10px;">
    <span class="journal-badge" style="font-size: 0.9rem; padding: 5px 10px;">👍 {{ nom.upvotes }}</span>
    <span class="journal-badge" style="font-size: 0.9rem; padding: 5px 10px;">🎉 {{ nom.predictSuccess }}</span>
    <span class="journal-badge" style="font-size: 0.9rem; padding: 5px 10px;">😕 {{ nom.predictFailure }}</span>
    <a href="{{ nom.url }}" target="_blank" class="upvote-btn" style="margin-left: 10px;">Vote &rarr;</a>
  </div>
</div>

{% if nom.seekingCollab %}
<div style="background: rgba(59, 130, 246, 0.05); border-left: 4px solid #3b82f6; padding: 15px 20px; margin-bottom: 25px; border-radius: 0 4px 4px 0;">
  <strong style="color: #3b82f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 0.9rem; text-transform: uppercase;">Collaborators Needed</strong>
  <p style="margin: 5px 0 0 0; font-size: 0.95rem;">A researcher is actively looking for collaborators to execute this {{ nom.type | lower }}. <a href="{{ nom.url }}" target="_blank" style="color: #3b82f6; text-decoration: underline; text-underline-offset: 3px;">Join the discussion on GitHub &rarr;</a></p>
</div>
{% endif %}

<div class="meta-box" style="border-top: 3px solid var(--gold);">
  <p><strong>Nominated by:</strong> <a href="https://github.com/{{ nom.nominator }}" target="_blank">@{{ nom.nominator }}</a></p>
  <p><strong>DOI:</strong> <a href="https://doi.org/{{ nom.DOI }}" target="_blank">{{ nom.DOI }}</a></p>
  <p><strong>Journal:</strong> {{ nom.Journal }}</p>
  <p><strong>Discipline:</strong> {{ nom.Discipline }}</p>
  <p><strong>Request Type:</strong> <span class="type-badge type-{{ nom.type | lower }}">{{ nom.type }}</span></p>
  
  {% if nom.targetJournals.length > 0 %}
    <p style="margin-top: 10px;"><strong>Target Journals:</strong> 
      {% for journal in nom.targetJournals %}
        <span class="journal-badge" data-tooltip="{{ journalNames[journal] | default(journal) }}">{{ journal }}</span>
      {% endfor %}
    </p>
  {% endif %}
</div>

<div style="margin-top: 40px;">
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Scientific Justification</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Scientific Justification'] }}</p>

  {% if nom['Data Location (if Reproduction)'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Data Location</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Data Location (if Reproduction)'] }}</p>
  {% endif %}

  {% if nom['Suggested Robustness Checks'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Suggested Robustness Checks</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Suggested Robustness Checks'] }}</p>
  {% endif %}

  {% if nom['Suggested Deviations from Original Design'] %}
  <h4 class="serif" style="border-bottom: 1px solid var(--border); padding-bottom: 5px; margin-bottom: 10px; color: var(--gold);">Suggested Deviations</h4>
  <p style="white-space: pre-wrap; margin-bottom: 30px;">{{ nom['Suggested Deviations from Original Design'] }}</p>
  {% endif %}
</div>

<hr style="margin: 50px 0 30px 0; border: 0; border-top: 1px solid var(--border);">
<h2 id="comments" class="serif">Comments</h2>

{% if nom.commentCount == 0 %}
  <p style="color: var(--text-muted); margin-bottom: 20px;">No comments yet on this nomination.</p>
{% else %}
  <div style="margin-bottom: 30px;">
    {% for comment in nom.discussion %}
      <div style="background: var(--bg); padding: 20px; border: 1px solid var(--border); border-radius: 0px; margin-bottom: 15px;">
        <strong style="color: var(--gold);">@{{ comment.author }}</strong> 
        <span style="color: var(--text-muted); font-size: 0.85rem; margin-left: 10px;">{{ comment.date }}</span>
        <div style="margin-top: 10px; font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap;">{{ comment.body }}</div>
      </div>
    {% endfor %}
  </div>
{% endif %}

<a href="{{ nom.url }}" target="_blank" class="nav-submit" style="display: inline-block; font-size: 1rem;">Join discussion on GitHub &rarr;</a>
