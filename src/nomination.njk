---
layout: base.njk
pagination:
  data: nominations
  size: 1
  alias: nom
permalink: "nomination/{{ nom.id }}/"
---
<a href="{{ '/browse/' | url }}" class="back-link" style="display:inline-block; margin-bottom: 20px;">&larr; Back to Browse</a>

<h1 style="margin-top: 0;">{{ nom.title }}</h1>
<!-- Removed the inline white background so it uses var(--card-bg) -->
<div class="meta-box" style="border-top: 3px solid var(--accent);">
  <p><strong>Nominated by:</strong> <a href="https://github.com/{{ nom.nominator }}" target="_blank">@{{ nom.nominator }}</a></p>
  <p><strong>DOI:</strong> <a href="https://doi.org/{{ nom.DOI }}" target="_blank">{{ nom.DOI }}</a></p>
  <p><strong>Journal:</strong> {{ nom.Journal }}</p>
  <p><strong>Discipline:</strong> {{ nom.Discipline }}</p>
  <p><strong>Request Type:</strong> <span class="type-badge type-{{ nom.type | lower }}">{{ nom.type }}</span></p>
</div>

<h3 class="serif">Scientific Justification</h3>
<p style="white-space: pre-wrap;">{{ nom['Scientific Justification'] }}</p>

{% if nom['Data Location (if Reproduction)'] %}
<h3 class="serif">Data Location</h3>
<p style="white-space: pre-wrap;">{{ nom['Data Location (if Reproduction)'] }}</p>
{% endif %}

{% if nom['Suggested Robustness Checks'] %}
<h3 class="serif">Suggested Robustness Checks</h3>
<p style="white-space: pre-wrap;">{{ nom['Suggested Robustness Checks'] }}</p>
{% endif %}

{% if nom['Suggested Deviations from Original Design'] %}
<h3 class="serif">Suggested Deviations</h3>
<p style="white-space: pre-wrap;">{{ nom['Suggested Deviations from Original Design'] }}</p>
{% endif %}

<!-- Comments Section -->
<hr style="margin: 50px 0 30px 0; border: 0; border-top: 1px solid var(--border);">
<h2 id="comments" class="serif">Comments</h2>

{% if nom.commentCount == 0 %}
  <p style="color: var(--text-muted); margin-bottom: 20px;">No comments yet on this nomination.</p>
{% else %}
  <div style="margin-bottom: 20px;">
    {% for comment in nom.discussion %}
      <!-- Updated background here to var(--card-bg) for dark mode compatibility -->
      <div style="background: var(--card-bg); padding: 20px; border: 1px solid var(--border); border-radius: 6px; margin-bottom: 15px;">
        <strong style="color: var(--link);">@{{ comment.author }}</strong> 
